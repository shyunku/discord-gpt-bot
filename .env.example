# Required: copy this file to .env and fill in these three values.
DISCORD_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=

# OpenAI Responses API settings
OPENAI_BASE_URL=https://api.openai.com/v1
MAX_OUTPUT_TOKENS=2048
OPENAI_REASONING_EFFORT=medium
SYSTEM_PROMPT=You are a helpful, accurate, and concise assistant. Reply in the user's language.
OPENAI_TIMEOUT_MS=120000
OPENAI_MAX_RETRIES=2

# Discord behavior
# REPLY_MODE: mention | detect | both | all
REPLY_MODE=both
# CONVERSATION_SCOPE: channel | user | channel-user
CONVERSATION_SCOPE=channel-user
MAX_HISTORY_MESSAGES=20
MAX_CONVERSATIONS=500
CONVERSATION_TTL_MINUTES=60
SQLITE_PATH=./data/conversations.db
USER_COOLDOWN_MS=1000
MAX_INPUT_CHARS=12000
