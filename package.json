{
  "name": "discord-gpt-bot",
  "version": "1.0.1",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "description": "A configurable, general-purpose ChatGPT bot for Discord",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "check": "node --check src/index.js && node --test",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart discord-gpt-bot --update-env",
    "pm2:logs": "pm2 logs discord-gpt-bot",
    "pm2:stop": "pm2 stop discord-gpt-bot",
    "pm2:delete": "pm2 delete discord-gpt-bot"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "discord.js": "14.27.0",
    "dotenv": "16.4.7"
  },
  "devDependencies": {
    "pm2": "7.0.3"
  }
}
